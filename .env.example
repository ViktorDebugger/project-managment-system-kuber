# Root .env (used by docker-compose)
JWT_SECRET="your-jwt-secret"

# All env vars reference (copy to services/<name>/.env for local dev)
# DBs (host ports): user_db (5435), workspace_db (5436), project_task_db (5437)
# Redis (host port): 6379
DATABASE_URL="postgresql://user:password@localhost:5435/user_auth_db"
REDIS_URL="redis://localhost:6379"
CACHE_TTL_SECONDS=300
USER_SERVICE_URL="http://localhost:3001"
WORKSPACE_SERVICE_URL="http://localhost:3002"
PROJECT_TASK_SERVICE_URL="http://localhost:3003"
PORT=3000
