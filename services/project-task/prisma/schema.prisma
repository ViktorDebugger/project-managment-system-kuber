generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  workspaceId String
  tasks       Task[]
  sprints     Sprint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("projects")
}

model Sprint {
  id        String   @id @default(uuid())
  name      String
  goal      String?
  startDate DateTime
  endDate   DateTime
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sprints")
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  projectId   String
  deadline    DateTime?
  sprintId    String?
  tagIds      Json?        @default("[]")
  assigneeIds Json?        @default("[]")
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments    Comment[]
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  logs        Log[]
  sprint      Sprint?      @relation(fields: [sprintId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tasks")
}

model Comment {
  id      String @id @default(uuid())
  content String
  taskId  String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model Log {
  id      String  @id @default(uuid())
  taskId  String
  action  String
  message String?
  userId  String?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("logs")
}
